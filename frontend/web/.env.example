# API Configuration
VITE_API_URL=https://vrxlwtzfff.execute-api.us-east-1.amazonaws.com/dev
VITE_APP_ENV=development

# AWS Cognito (required for login; get from: cd infrastructure && terraform output cognito_user_pool_id cognito_app_client_id)
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# Google Maps API Key
# Optional: can also be fetched at runtime via GET /config from backend
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mock mode (set to true to skip real API calls for local testing)
# VITE_USE_MOCK_API=true
