# API Configuration
VITE_API_URL=https://vrxlwtzfff.execute-api.us-east-1.amazonaws.com/dev
VITE_APP_ENV=development

# Google Maps API Key
# This key is safe to expose in the frontend as it's restricted by domain in Google Cloud Console
# Get this from: AWS Secrets Manager -> google-maps-config secret -> api_key field
# Or ask your backend team for the key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
