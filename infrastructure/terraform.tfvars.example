# Copy to terraform.tfvars and fill in your values

project_name = "emergency-medical-triage"
aws_region   = "us-east-1"
environment  = "dev"

# WARNING: Do not change db_username after first apply - it forces Aurora replacement
# RDS password: only printable ASCII; no '/', '@', '"', or space
db_username = "triagemaster"
db_password = "CHANGE_ME_STRONG_PASSWORD"

# Bastion (optional - SSH tunnel to Aurora)
# enable_bastion        = true
# bastion_ssh_public_key = "ssh-rsa AAAA... your@email"
# bastion_allowed_cidr   = "YOUR_IP/32"   # e.g. curl -s ifconfig.me

# Google Maps (optional – real directions for POST /route; leave empty for stub)
# google_maps_api_key   = "AIza..."

# Web app custom domain (optional). Leave empty to use default CloudFront URL (e.g. https://xxx.cloudfront.net).
# Certificate must be in us-east-1. After apply, add a CNAME record: web_app_domain_name -> web_app_cloudfront_domain output.
# web_app_domain_name         = "app.example.com"
# web_app_acm_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT:certificate/xxx"

# Eka Care (optional – Indian drugs, treatment protocols via Gateway). Requires Client ID + Client Secret; Lambda uses login API to get access token.
# Get both from https://console.eka.care . See https://developer.eka.care/user-guides/get-started
# eka_api_key        = "your-client-id"
# eka_client_secret  = "your-client-secret"

# RMP Learning (Group C – Eka quiz). Set after: cd agentcore/agent && agentcore deploy --agent rmp_quiz_agent
# rmp_quiz_agent_runtime_arn = "arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/rmp_quiz_agent-xxx"
